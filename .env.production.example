# Copy this file to a protected server-side env file and replace every placeholder.
# Do not commit the populated file.

EDR_LOG_LEVEL=INFO
EDR_ACCESS_TOKEN_TTL_SECONDS=43200
EDR_JWT_SECRET=replace-with-a-long-random-secret

POSTGRES_DB=edr
POSTGRES_USER=edr
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

CLICKHOUSE_DB=edr
CLICKHOUSE_USER=edr
CLICKHOUSE_PASSWORD=replace-with-a-strong-clickhouse-password

# Required for the EC2 IAM Role based S3 connection.
EDR_AWS_REGION=ap-northeast-2
EDR_S3_BUCKET=replace-with-the-existing-private-s3-bucket-name

EDR_KAFKA_RAW_TOPIC=telemetry.raw
EDR_KAFKA_VALIDATED_TOPIC=telemetry.validated
EDR_KAFKA_PARTITIONS_PER_TOPIC=2
EDR_KAFKA_REPLICATION_FACTOR=1
EDR_EVENT_STORAGE_CONSUMER_GROUP=edr-event-storage-v1
EDR_DETECTION_CONSUMER_GROUP=edr-detection-v1

# Existing production TLS files: server.crt, server.key, and agent-ca.crt.
EDR_NGINX_CERT_DIR=/etc/edr-c/tls
NGINX_HTTP_HOST_PORT=8080
NGINX_MTLS_HOST_PORT=8443

# Frontend build/runtime feature gate. false면 Incident graph 대신 Timeline/Table fallback을 사용한다.
VITE_INCIDENT_GRAPH_ENABLED=true

# Frontend build/runtime feature gate. false면 Egress graph 대신 Inspector/Table fallback을 사용한다.
VITE_TOPOLOGY_GRAPH_ENABLED=true
