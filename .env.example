# 실행 환경
EDR_ENV=local
EDR_LOG_LEVEL=INFO

# Dashboard 인증. 로컬에서 교체하고 실제 값은 절대 commit하지 않는다.
EDR_JWT_SECRET=replace-with-a-long-random-secret
EDR_ACCESS_TOKEN_TTL_SECONDS=43200

# PostgreSQL 운영 데이터
POSTGRES_DB=edr
POSTGRES_USER=edr
POSTGRES_PASSWORD=replace-with-a-local-password
POSTGRES_HOST_PORT=55432
EDR_POSTGRES_DSN=postgresql://edr:replace-with-a-local-password@127.0.0.1:55432/edr

# ClickHouse event 및 failure index
CLICKHOUSE_DB=edr
CLICKHOUSE_USER=edr
CLICKHOUSE_PASSWORD=replace-with-a-local-password
CLICKHOUSE_HTTP_HOST_PORT=58123
CLICKHOUSE_NATIVE_HOST_PORT=59009
EDR_CLICKHOUSE_DSN=http://edr:replace-with-a-local-password@127.0.0.1:58123/edr

# Kafka 전송
KAFKA_HOST_PORT=59092
EDR_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:59092

# S3 호환 로컬 저장소
MINIO_ROOT_USER=edr-local
MINIO_ROOT_PASSWORD=replace-with-a-local-password
MINIO_API_HOST_PORT=59000
MINIO_CONSOLE_HOST_PORT=59001
EDR_S3_ENDPOINT_URL=http://127.0.0.1:59000
EDR_S3_ACCESS_KEY_ID=edr-local
EDR_S3_SECRET_ACCESS_KEY=replace-with-a-local-password
EDR_S3_BUCKET=edr-failures

# Local Compose의 단일 진입점. 8443은 Collector mTLS 전용이다.
NGINX_HTTP_HOST_PORT=8080
NGINX_MTLS_HOST_PORT=8443
