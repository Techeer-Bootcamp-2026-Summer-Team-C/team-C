EDR_IMAGE_TAG=<40-character-git-commit-sha>
EDR_JWT_SECRET=<random-string-at-least-32-characters>
EDR_POSTGRES_DSN=postgresql://<user>:<url-encoded-password>@postgres:5432/<database>
EDR_CLICKHOUSE_DSN=http://<user>:<url-encoded-password>@clickhouse:8123/<database>
EDR_AWS_REGION=ap-northeast-2
EDR_S3_BUCKET=<s3-bucket-name>
NGINX_HTTP_HOST_PORT=8080
NGINX_MTLS_HOST_PORT=8443
