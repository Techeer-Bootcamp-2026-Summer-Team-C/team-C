{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:edr:schema:rule-v1",
  "title": "RuleV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "rule_code",
    "rule_name",
    "alert_title",
    "alert_summary",
    "version",
    "enabled",
    "event_type",
    "conditions",
    "severity",
    "risk_score",
    "incident"
  ],
  "allOf": [
    {
      "if": {"properties": {"enabled": {"const": true}}, "required": ["enabled"]},
      "then": {"required": ["mitre"]},
      "else": {"not": {"required": ["mitre"]}}
    }
  ],
  "properties": {
    "schema_version": {"const": 1},
    "rule_code": {"type": "string", "minLength": 1},
    "rule_name": {"type": "string", "minLength": 1},
    "alert_title": {"type": "string", "minLength": 1},
    "alert_summary": {"type": "string", "minLength": 1},
    "version": {"type": "integer", "minimum": 1},
    "enabled": {"type": "boolean"},
    "event_type": {
      "enum": [
        "PROCESS_EXECUTION",
        "NETWORK_CONNECTION",
        "FILE_EVENT",
        "DNS_QUERY",
        "L7_EVENT"
      ]
    },
    "conditions": {"$ref": "#/$defs/conditionGroup"},
    "severity": {"enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]},
    "risk_score": {"type": "number", "minimum": 0, "maximum": 100},
    "mitre": {"$ref": "#/$defs/mitre"},
    "incident": {"$ref": "#/$defs/incident"},
    "response_guidance": {
      "type": "array",
      "items": {"$ref": "#/$defs/responseGuidanceStep"}
    }
  },
  "$defs": {
    "conditionGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all"],
      "properties": {
        "all": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/condition"}
        }
      }
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "operator", "value"],
      "properties": {
        "field": {"type": "string", "minLength": 1},
        "operator": {
          "enum": ["eq", "neq", "contains", "regex", "in", "cidr_contains", "gt", "gte", "lt", "lte"]
        },
        "value": {}
      }
    },
    "mitre": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tactic_code", "technique_code"],
      "properties": {
        "tactic_code": {"type": "string", "pattern": "^TA[0-9]{4}$"},
        "technique_code": {"type": "string", "pattern": "^T[0-9]{4}(\\.[0-9]{3})?$"}
      }
    },
    "incident": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {"type": "boolean"},
        "correlation_key": {"type": "string", "minLength": 1},
        "window_seconds": {"type": "integer", "minimum": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"enabled": {"const": true}}, "required": ["enabled"]},
          "then": {"required": ["correlation_key", "window_seconds"]},
          "else": {
            "not": {
              "anyOf": [
                {"required": ["correlation_key"]},
                {"required": ["window_seconds"]}
              ]
            }
          }
        }
      ]
    },
    "responseGuidanceStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["order", "title", "description", "requires_manual_action"],
      "properties": {
        "order": {"type": "integer", "minimum": 1},
        "title": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "requires_manual_action": {"type": "boolean"}
      }
    }
  }
}
