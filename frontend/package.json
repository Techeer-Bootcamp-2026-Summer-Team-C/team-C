{
  "name": "edr-c-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:contracts": "tsc -b --pretty false",
    "openapi:export": "cd .. && uv run python -m tools.export_openapi",
    "openapi:generate": "openapi-typescript ../openapi/openapi.json -o src/api/generated/schema.ts --default-non-nullable false",
    "openapi:check": "cd .. && uv run python -m tools.export_openapi --check && cd frontend && openapi-typescript ../openapi/openapi.json -o src/api/generated/schema.ts --default-non-nullable false --check"
  },
  "dependencies": {
    "@dagrejs/dagre": "3.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@tanstack/react-query": "5.90.21",
    "@xyflow/react": "12.11.2",
    "echarts": "^6.1.0",
    "lucide-react": "0.468.0",
    "pretendard": "^1.3.9",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router-dom": "7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "9.39.3",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "jsdom": "27.4.0",
    "openapi-typescript": "7.13.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  }
}
