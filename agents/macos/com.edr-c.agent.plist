<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.edr-c.agent</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/libexec/edr-macos-agent</string>
    <string>--config</string>
    <string>/Library/Application Support/EDR-C-Agent/config.json</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Library/Logs/EDR-C-Agent.log</string>
  <key>StandardErrorPath</key>
  <string>/Library/Logs/EDR-C-Agent.error.log</string>
</dict>
</plist>
